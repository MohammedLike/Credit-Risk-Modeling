# Environment Configuration Template
# Copy to .env and modify as needed

# Data Generation
N_SAMPLES=50000
DEFAULT_RATE=0.08
RANDOM_SEED=42

# Model Parameters
TEST_SIZE=0.25
VALIDATION_SIZE=0.15
N_FOLDS=5

# Flask Web App
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# Decision Engine
APPROVAL_EL_THRESHOLD=0.05
BASE_INTEREST_RATE=0.08
PRICING_SCALAR=10.0

# Real Data (Optional)
# Set to True to load real data instead of synthetic
USE_REAL_DATA=False
REAL_DATA_PATH=
DATASET_NAME=synthetic  # 'lending_club', 'kaggle_credit', or 'synthetic'

# Basel III
CONFIDENCE_LEVEL=0.999
MATURITY=2.5
LGD_DOWNTURN_MULTIPLIER=1.2
